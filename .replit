run = "npm run dev"
entrypoint = "server/index.ts"
modules = ["nodejs-20"]

[deployment]
run = ["npm", "start"]
deploymentTarget = "autoscale"
build = ["npm", "run", "build"]

[nix]
channel = "stable-24_05"

[env]
NODE_ENV = "development"

[[ports]]
localPort = 5000
externalPort = 80

[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 120000
